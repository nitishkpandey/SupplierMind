# ============================================================
# SUPPLIERMIND .gitignore
# ============================================================

# --- THESIS DOCUMENTS (local only) ---
Documents/

# --- SECRETS (NEVER commit these) ---
.env
.env.local
*.pem
*.key
secrets/

# --- PYTHON ---
venv/
.venv/
__pycache__/
*.py[cod]
*.so
build/
dist/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- ALEMBIC ---
alembic/__pycache__/

# --- NODE.JS / FRONTEND ---
node_modules/
dist/
*.tsbuildinfo
.eslintcache

# --- DOCKER ---
infra/docker/docker-compose.override.yml

# --- VECTOR DB LOCAL DATA ---
chroma_db/
milvus_data/

# --- IDE ---
.vscode/
!.vscode/extensions.json
.idea/
*.swp
.DS_Store
Thumbs.db

# --- LOGS ---
logs/
*.log

# --- TESTING ---
coverage/
# --- Task 2.1 bulk-ingest checkpoint (transient, regenerated per run) ---
apps/backend/data/bulk_ingest_checkpoint.json
apps/backend/data/bulk_ingest.log

# --- INTERNAL PLANNING / PROCESS DOCS (never commit) ---
docs/audits/
docs/verification/07_*
docs/verification/08_*
docs/verification/09_*
docs/superpowers/
codebase_walkthrough.md
known_bugs_to_triage.md
*_sprint_plan.md
*_plan.md

