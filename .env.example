# ============================================================
# SupplierMind Environment Variables
# INSTRUCTIONS: Copy this to .env and fill in real values
# NEVER commit .env to Git
# ============================================================

APP_ENV=development
APP_NAME=SupplierMind
LOG_LEVEL=INFO

# LLM — OpenAI is the benchmark/primary provider (gpt-4o-mini).
# REQUIRED: set OPENAI_API_KEY. Get a key at platform.openai.com.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini
# Groq is the legacy free-tier fallback (key optional; see GROQ_API_KEY).
GROQ_API_KEY=

# Embeddings — get free key at dash.voyageai.com
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=

# Vector DB (milvus or chromadb)
VECTOR_DB_PROVIDER=milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
CHROMA_PERSIST_PATH=./chroma_db

# PostgreSQL
POSTGRES_USER=suppliermind
POSTGRES_PASSWORD=suppliermind_dev
POSTGRES_DB=suppliermind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://suppliermind:suppliermind_dev@localhost:5432/suppliermind

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — generate SECRET_KEY with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Geocoding — replace with your actual email
NOMINATIM_USER_AGENT=suppliermind-thesis/1.0 your@email.com

# External APIs (optional — power external supplier discovery/enrichment)
OPENSANCTIONS_API_KEY=
TAVILY_API_KEY=
OPENCORPORATES_API_KEY=

# Set to true if Docker RAM is too low (uses ChromaDB instead of Milvus)
LITE_MODE=false