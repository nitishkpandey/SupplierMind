# k8s/secrets.yaml.example
# Copy to secrets.yaml, fill in values (base64 encoded), DO NOT COMMIT secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: suppliermind-secrets
  namespace: suppliermind
type: Opaque
stringData:
  GROQ_API_KEY: "your_groq_key"
  VOYAGE_API_KEY: "your_voyage_key"
  POSTGRES_USER: "suppliermind"
  POSTGRES_PASSWORD: "suppliermind_dev"
  DATABASE_URL: "postgresql+asyncpg://suppliermind:suppliermind_dev@postgres:5432/suppliermind"
  REDIS_URL: "redis://redis:6379/0"
  SECRET_KEY: "your_secret_key"
  FRONTEND_URL: "http://localhost:5173"
  MILVUS_HOST: "127.0.0.1"
  MILVUS_PORT: "19530"
  LITE_MODE: "true"
